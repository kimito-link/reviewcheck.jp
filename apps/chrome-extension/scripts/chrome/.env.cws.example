# Chrome Web Store API 認証情報（テンプレート）
# このファイルをコピーして同じフォルダ（または拡張ルート）に .env.cws を作り、値を埋める。
# .env.cws は .gitignore 済み（絶対にコミット/共有しない）。
#
#   Copy-Item scripts\chrome\.env.cws.example scripts\chrome\.env.cws   # PowerShell
#
# ポイント: OAuthクライアントは「デスクトップ アプリ」種別で作成すること。
# CLIENT_ID / CLIENT_SECRET / REFRESH_TOKEN は他拡張(マルウェアチェック等)と
# 使い回せる。ITEM_ID だけはこの拡張専用（初回にダッシュボードでアイテムを
# 作成すると確定する）。

# Google Cloud で作った OAuth 2.0 クライアント（デスクトップアプリ型）
CWS_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
CWS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# 初回だけ手作業で取得するリフレッシュトークン
CWS_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxx

# 口コミチェック.jp 拡張のアイテムID（初回にダッシュボードで
# 「+ 新しいアイテム」からこの dist の zip をアップロードすると確定）。
CWS_ITEM_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
